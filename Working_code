import os
import faiss
import numpy as np
import tempfile
import re
from google.colab import files
from google import genai
from google.genai import types
from pypdf import PdfReader
from docx import Document
from gtts import gTTS
from IPython.display import Audio, display

# ================================
# API KEY
# ================================

GEMINI_API_KEY = ""
client = genai.Client(api_key=GEMINI_API_KEY)

# ================================
# AUTO DETECT MODELS
# ================================

models = client.models.list()
all_models = [m.name for m in models]

EMBED_MODEL = next((m for m in all_models if "embedding" in m.lower()), None)
CHAT_MODEL = next((m for m in all_models if "flash" in m.lower()), None)

print("Embedding:", EMBED_MODEL)
print("Chat:", CHAT_MODEL)

# ================================
# UPLOAD FILE
# ================================

print("\nUpload Business Plan (PDF/DOCX/TXT)")
uploaded = files.upload()
file_name = list(uploaded.keys())[0]

def extract_text(file_name):
    if file_name.endswith(".pdf"):
        reader = PdfReader(file_name)
        return "".join(page.extract_text() or "" for page in reader.pages)
    elif file_name.endswith(".docx"):
        doc = Document(file_name)
        return "\n".join(p.text for p in doc.paragraphs)
    elif file_name.endswith(".txt"):
        return open(file_name, "r", encoding="utf-8").read()
    else:
        raise ValueError("Unsupported format")

text = extract_text(file_name)

# ================================
# SIMPLE CHUNKING
# ================================

def chunk_text(text, chunk_size=1200, overlap=200):
    chunks = []
    start = 0
    while start < len(text):
        end = start + chunk_size
        chunks.append(text[start:end])
        start += chunk_size - overlap
    return chunks

chunks = chunk_text(text)
print("Total chunks:", len(chunks))

# ================================
# EMBEDDINGS
# ================================

def embed_texts(texts):
    result = client.models.embed_content(
        model=EMBED_MODEL,
        contents=texts
    )
    return [e.values for e in result.embeddings]

embeddings = embed_texts(chunks)

# ================================
# BUILD FAISS INDEX
# ================================

dimension = len(embeddings[0])
index = faiss.IndexFlatL2(dimension)

vectors = np.array(embeddings).astype("float32")
index.add(vectors)

print("Vector DB ready!")

# ================================
# RETRIEVAL FUNCTION
# ================================

def retrieve(query, k=4):
    query_embedding = embed_texts([query])[0]
    query_vector = np.array([query_embedding]).astype("float32")
    distances, indices = index.search(query_vector, k)
    return [chunks[i] for i in indices[0]]

# ================================
# ASK FUNCTION (RAG)
# ================================

def ask(question):

    context_chunks = retrieve(question)
    context = "\n\n".join(context_chunks)

    prompt = f"""
You are an expert business analyst.

Use the context below to answer the question.
If insufficient info, say so.

Context:
{context}

Question:
{question}

Answer:
"""

    response = client.models.generate_content(
        model=CHAT_MODEL,
        contents=prompt,
        config=types.GenerateContentConfig(
            temperature=0.2
        )
    )

    return response.text

# ================================
# CEO ANALYSIS
# ================================

analysis_prompt = """
You are an AI CEO and VC analyst.

Provide:
1. Executive Summary
2. Business Model Evaluation
3. Market Opportunity
4. Revenue Risks
5. Cost Optimization
6. Competitive Weaknesses
7. Missing KPIs
8. Investor Concerns
9. Strategic Recommendations
10. 90-Day Roadmap
"""

print("\nRunning CEO Analysis...\n")
print(ask(analysis_prompt))

# ================================
# EXECUTIVE PANEL
# ================================

panel_questions = [
    "Act as a CFO. What financial risks exist?",
    "Act as a COO. What execution problems may occur?",
    "Act as a Venture Capitalist. Would you invest? Why or why not?"
]

for q in panel_questions:
    print("\n---", q, "---\n")
    print(ask(q))

# ================================
# TEXT TO SPEECH
# ================================

def speak(text):
    clean = re.sub(r"[*#`_]", "", text)
    clean = re.sub(r"\n+", ". ", clean)
    tts = gTTS(text=clean, lang="en")
    with tempfile.NamedTemporaryFile(delete=False, suffix=".mp3") as f:
        tts.save(f.name)
        display(Audio(f.name, autoplay=True))

# ================================
# INTERACTIVE MODE
# ================================

print("\nCEO Agent Ready. Type 'exit' to stop.\n")

while True:
    q = input("You: ")
    if q.lower() == "exit":
        break
    response = ask(q)
    print("\nCEO:", response)
    speak(response)
