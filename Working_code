# 14. TEXT-TO-SPEECH SETUP
# Plays AI answers as voice in Google Colab
# -------------------------------
from gtts import gTTS
from IPython.display import Audio, display
import tempfile, os

def speak(text):
    """Convert text to speech and auto-play in Colab."""
    try:
        # Clean text — remove markdown symbols that sound bad when read aloud
        import re
        clean = re.sub(r"[*#`_]", "", text)          # remove *, #, `, _
        clean = re.sub(r"\n+", ". ", clean)           # newlines → pauses
        clean = re.sub(r"\s+", " ", clean).strip()    # collapse spaces

        tts = gTTS(text=clean, lang="en", slow=False)

        # Save to temp file and play
        with tempfile.NamedTemporaryFile(delete=False, suffix=".mp3") as f:
            tts.save(f.name)
            display(Audio(f.name, autoplay=True))

    except Exception as e:
        print(f"[Voice error: {e}]")


