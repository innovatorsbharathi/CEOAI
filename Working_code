import time, re

# Fallback chain — tries cheaper/lighter models if quota hit
CHAT_FALLBACKS = [m for m in [
    "models/gemini-2.0-flash-lite",
    "models/gemini-1.5-flash-8b",
    "models/gemini-1.5-flash",
    "models/gemini-2.0-flash",
    "models/gemini-1.5-pro",
] if m in all_models]

_active_model = CHAT_MODEL   # global, updated on fallback

class GeminiChat(SimpleChatModel):
    model: str = CHAT_MODEL
    temperature: float = 0.2

    def _call(self, messages: list[BaseMessage], stop=None, run_manager=None, **kwargs) -> str:
        global _active_model
        prompt = "\n".join(m.content for m in messages)

        tried = set()
        candidates = [_active_model] + [m for m in CHAT_FALLBACKS if m != _active_model]

        for model in candidates:
            if model in tried:
                continue
            tried.add(model)
            try:
                response = client.models.generate_content(
                    model=model,
                    contents=prompt,
                    config=types.GenerateContentConfig(temperature=self.temperature),
                )
                _active_model = model   # remember what worked
                return response.text

            except Exception as e:
                err = str(e)
                if "429" in err or "RESOURCE_EXHAUSTED" in err:
                    wait_match = re.search(r"retry in ([\d.]+)s", err)
                    wait = float(wait_match.group(1)) + 2 if wait_match else 15
                    print(f"⚠️  Quota hit on {model}. Trying next model...")
                    time.sleep(2)   # brief pause before next attempt
                    continue
                else:
                    raise

        # Last resort: wait and retry original model
        print(f"All models quota-hit. Waiting 60s then retrying {CHAT_FALLBACKS[-1]}...")
        time.sleep(60)
        response = client.models.generate_content(
            model=CHAT_FALLBACKS[-1],
            contents=prompt,
            config=types.GenerateContentConfig(temperature=self.temperature),
        )
        return response.text

    @property
    def _llm_type(self) -> str:
        return "gemini"

print(f"Chat model      : {_active_model}")
print(f"Fallback chain  : {' → '.join(CHAT_FALLBACKS)}")
llm = GeminiChat()


